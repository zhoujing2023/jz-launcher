<?xml version="1.0" encoding="UTF-8"?>
<!-- resources.gresource.xml 资源清单 -->
<!-- 这个 XML 文件告诉构建工具，哪些文件（比如：launcher-window.ui）需要被打包，以及它们最终在程序内部以什么路径（prefix）和名称被访问 -->
<!-- 以下例子中 launcher-window.ui 最终会被打包，并在程序中通过 resource:///org/gtk_rs/example/launcher-window.ui 这个 URI 来访问 -->
<gresources>
    <gresource prefix="/org/zhoujing/jz-launcher/">
        <file compressed="true" preprocess="xml-stripblanks">ui/launcher-window.ui</file>
        <file compressed="true" preprocess="xml-stripblanks">ui/settings-window.ui</file>
        <file compressed="true" preprocess="xml-stripblanks">ui/search-result-item.ui</file>
        <file compressed="true">css/launcher.css</file>
        <file compressed="true">css/settings.css</file>
        <file compressed="true">icon/gitee.svg</file>
        <file compressed="true">icon/github.svg</file>
    </gresource>
</gresources>
