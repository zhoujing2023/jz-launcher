{
  "general": {
    "auto_start_at_boot": false,
    "desktop_scan_path": [
      "${HOME}/.local/share/applications",
      "/usr/share/applications",
      "/var/lib/snapd/desktop/applications"
    ]
  },
  "appearance": {
    "theme": 1,
    "font_size": 12.0
  },
  "shortcut": {
    "show": "<Shift>space",
    "hide": "<Control>q"
  }
}